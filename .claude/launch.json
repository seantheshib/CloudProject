{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "CloudGraph Frontend (Vite)",
      "runtimeExecutable": "node",
      "runtimeArgs": ["FrontEnd/node_modules/vite/bin/vite.js", "FrontEnd", "--config", "FrontEnd/vite.config.js"],
      "port": 3000
    },
    {
      "name": "CloudGraph Backend (FastAPI)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--app-dir", "BackEnd"],
      "port": 8000
    }
  ]
}
